{
  "manifest_version": 3,
  "name": "UGC Lab — Kalodata Sync",
  "version": "0.1.0",
  "description": "Bắt dữ liệu Kalodata khi bạn browse và đẩy về UGC Lab Research.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://www.kalodata.com/*",
    "https://cashuqewfyypyldkutfx.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "UGC Lab — Kalodata Sync"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.kalodata.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.kalodata.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
